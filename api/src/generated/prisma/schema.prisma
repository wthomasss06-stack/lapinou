// rabbit-shop — Prisma Schema PRODUCTION
// Provider : PostgreSQL — Neon
// Utilisé via : npm run db:push:prod

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl = env("DIRECT_URL") // décommentez si vous utilisez un pooler Neon (PgBouncer)
}

// ─── Lapin ────────────────────────────────────────────────────────────────────
// Modèle "fiche de race en stock" — une fiche représente une race/portée avec
// une quantité disponible (stock), pas un individu unique.
model Rabbit {
  id   String @id @default(cuid())
  slug String @unique

  // Identité
  name        String // nom de la fiche/portée, ex: "Bélier nain Fauve"
  breed       String // ex: "Bélier nain", "Rex"
  color       String
  gender      String // "male" | "female" | "mixed" (lot mixte)
  birthDate   DateTime?
  weight      Float? // kg
  description String?

  // Prix (à l'unité)
  price     Float
  priceNote String? // "négociable", "incluant vaccins", etc.

  // Stock — quantité de lapins disponibles sur cette fiche
  stock Int @default(0)

  // Statut dérivé du stock, mais stocké pour permettre un forçage manuel admin
  // available → stock > 0, réservable
  // sold      → stock épuisé (0), grisé côté client
  status String @default("available") // "available" | "sold"

  // Médias
  photos RabbitPhoto[]

  // Réservations
  reservations Reservation[]

  // Dates
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([slug])
  @@index([breed])
}

// ─── Photos ───────────────────────────────────────────────────────────────────
model RabbitPhoto {
  id       Int     @id @default(autoincrement())
  rabbitId String
  rabbit   Rabbit  @relation(fields: [rabbitId], references: [id], onDelete: Cascade)
  url      String // URL Cloudinary (secure_url)
  publicId String? // public_id Cloudinary — nécessaire pour la suppression
  position Int     @default(0) // ordre d'affichage
  isMain   Boolean @default(false) // photo principale = couverture
}

// ─── Réservation ──────────────────────────────────────────────────────────────
model Reservation {
  id String @id @default(cuid())

  // Quel lapin (quelle fiche de race)
  rabbitId String
  rabbit   Rabbit @relation(fields: [rabbitId], references: [id])

  // Quantité réservée sur cette commande — décomptée du stock immédiatement
  quantity Int @default(1)

  // Acheteur
  firstName String
  lastName  String
  email     String
  phone     String
  message   String?

  // Statut de la réservation
  // pending   → soumise, stock déjà décompté
  // confirmed → confirmée par le vendeur (WhatsApp / tel)
  // cancelled → annulée, le stock réservé est restitué à la fiche
  status String @default("pending") // "pending" | "confirmed" | "cancelled"

  // Coordonnées GPS client
  latitude  Float?
  longitude Float?

  // Livraison — zone résolue automatiquement depuis lat/lng (cf lib/delivery.js)
  // "abidjan" -> 2000 FCFA | "azaguie" -> 1000 FCFA | "pays_profond" -> 3000 FCFA
  deliveryZone String?
  deliveryFee  Float?

  // Confirmation WhatsApp
  confirmedAt DateTime?
  note        String? // note interne du vendeur

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rabbitId])
  @@index([email])
  @@index([status])
}

// ─── Analytics ─────────────────────────────────────────────────────────────────
model VisitStats {
  id       String @id @default("global")
  accepted Int    @default(0)
  declined Int    @default(0)
  total    Int    @default(0)
}
