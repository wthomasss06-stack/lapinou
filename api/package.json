{
  "name": "rabbit-shop-api",
  "version": "1.0.0",
  "description": "API Express pour rabbit-shop",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "postinstall": "node ./scripts/generate-prisma-client.js",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema.prisma",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio --schema=prisma/schema.prisma",
    "db:reset": "prisma db push --force-reset --schema=prisma/schema.prisma",
    "db:generate:prod": "prisma generate --schema=prisma/schema.production.prisma",
    "db:push:prod": "prisma db push --schema=prisma/schema.production.prisma",
    "db:seed:prod": "prisma db seed -- --schema=prisma/schema.production.prisma",
    "db:studio:prod": "prisma studio --schema=prisma/schema.production.prisma",
    "db:setup": "npm run db:generate && npm run db:push && npm run db:seed"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "multer": "^2.0.0",
    "resend": "^3.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.3",
    "prisma": "^5.14.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}

