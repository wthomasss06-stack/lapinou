{
  "name": "rabbit-shop-api",
  "version": "1.0.0",
  "description": "API Express pour rabbit-shop",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "preinstall": "node -e \"const fs = require('fs'); if (!fs.existsSync('../prisma')) { fs.mkdirSync('../prisma', { recursive: true }); } if (fs.existsSync('prisma')) { fs.readdirSync('prisma').forEach(f => fs.copyFileSync('prisma/' + f, '../prisma/' + f)); }\""
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "multer": "^2.0.0",
    "resend": "^3.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.3",
    "prisma": "^5.14.0"
  },
  "prisma": {
    "schema": "../prisma/schema.prisma",
    "seed": "node ../prisma/seed.js"
  }
}
