// rabbit-shop — Prisma Schema
// Dev  : SQLite  → fichier local prisma/dev.db  (DATABASE_URL=file:./dev.db)
// Prod : échanger le provider en "postgresql" + pointer vers Neon
//        ou utiliser : npm run db:prod

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Lapin ────────────────────────────────────────────────────────────────────
// Modèle "fiche de race en stock" — Aka a trop de lapins pour les publier un par
// un. Une fiche représente maintenant une race/portée avec une quantité
// disponible (stock), pas un individu unique. Le client choisit une quantité
// et réserve ; le stock décompte immédiatement (comme un panier classique).
model Rabbit {
  id          String   @id @default(cuid())
  slug        String   @unique

  // Identité
  name        String                         // nom de la fiche/portée, ex: "Bélier nain Fauve"
  breed       String                         // ex: "Bélier nain", "Rex"
  color       String
  gender      String                         // "male" | "female" | "mixed" (lot mixte)
  birthDate   DateTime?
  weight      Float?                         // kg
  description String?

  // Prix (à l'unité)
  price       Float
  priceNote   String?                        // "négociable", "incluant vaccins", etc.

  // Stock — quantité de lapins disponibles sur cette fiche
  stock       Int      @default(0)

  // Statut dérivé du stock, mais stocké pour permettre un forçage manuel admin
  // (ex: retirer temporairement une fiche sans toucher au stock réel)
  // available → stock > 0, réservable
  // sold      → stock épuisé (0), grisé côté client
  status      String   @default("available") // "available" | "sold"

  // Médias
  photos      RabbitPhoto[]

  // Réservations
  reservations Reservation[]

  // Dates
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([slug])
  @@index([breed])
}

// ─── Photos ───────────────────────────────────────────────────────────────────
// Pattern AnnoncePhoto de Nexura : plusieurs photos ordonnées par position
model RabbitPhoto {
  id        Int     @id @default(autoincrement())
  rabbitId  String
  rabbit    Rabbit  @relation(fields: [rabbitId], references: [id], onDelete: Cascade)
  url       String                              // URL Cloudinary (secure_url)
  publicId  String?                             // public_id Cloudinary — nécessaire pour la suppression
  position  Int     @default(0)                // ordre d'affichage
  isMain    Boolean @default(false)            // photo principale = couverture
}

// ─── Réservation ──────────────────────────────────────────────────────────────
// Pattern Transaction de Nexura (simplifié)
model Reservation {
  id        String   @id @default(cuid())

  // Quel lapin (quelle fiche de race)
  rabbitId  String
  rabbit    Rabbit   @relation(fields: [rabbitId], references: [id])

  // Quantité réservée sur cette commande — décomptée du stock immédiatement
  quantity  Int      @default(1)

  // Acheteur
  firstName String
  lastName  String
  email     String
  phone     String
  message   String?

  // Statut de la réservation
  // pending   → soumise, stock déjà décompté
  // confirmed → confirmée par le vendeur (WhatsApp / tel)
  // cancelled → annulée, le stock réservé est restitué à la fiche
  status    String   @default("pending")       // "pending" | "confirmed" | "cancelled"

  // Coordonnées GPS client
  latitude  Float?
  longitude Float?

  // Livraison — zone résolue automatiquement depuis lat/lng (cf lib/delivery.js)
  // "abidjan" -> 2000 FCFA | "azaguie" -> 1000 FCFA | "pays_profond" -> 3000 FCFA
  deliveryZone String?
  deliveryFee  Float?

  // Confirmation WhatsApp
  confirmedAt DateTime?
  note        String?                          // note interne du vendeur

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rabbitId])
  @@index([email])
  @@index([status])
}

// ─── Analytics ─────────────────────────────────────────────────────────────────
model VisitStats {
  id        String   @id @default("global")
  accepted  Int      @default(0)
  declined  Int      @default(0)
  total     Int      @default(0)
}

